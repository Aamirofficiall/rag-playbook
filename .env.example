# At least one LLM provider required
RAG_OPENAI_API_KEY=sk-...
RAG_ANTHROPIC_API_KEY=sk-ant-...

# Custom base URL (e.g., OpenRouter, Azure, local proxy)
# RAG_OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Vector store (default: chromadb in-memory — zero setup)
# VECTOR_STORE=pgvector
# PGVECTOR_URL=postgresql://user:pass@localhost:5432/ragplaybook

# Embedding (default: OpenAI text-embedding-3-small)
# EMBEDDING_PROVIDER=local
