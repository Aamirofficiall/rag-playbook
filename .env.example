# rag-playbook configuration
# Environment variables map directly to settings — no prefix needed.

# --- LLM Provider (at least one required) ---
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Model settings ---
# DEFAULT_LLM_PROVIDER=openai              # openai | anthropic
# DEFAULT_LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# --- Custom base URL (OpenRouter, Azure, Ollama, etc.) ---
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_LLM_MODEL=openai/gpt-4o-mini    # OpenRouter model format

# --- Vector store (default: in-memory) ---
# VECTOR_STORE_PROVIDER=memory             # only "memory" is currently implemented

# --- Retrieval settings ---
# DEFAULT_TOP_K=5
# DEFAULT_CHUNK_SIZE=512
# DEFAULT_CHUNK_OVERLAP=50

# --- LLM retry/timeout ---
# LLM_MAX_RETRIES=3
# LLM_TIMEOUT_SECONDS=30
